-- [ ระบบสปิน 360 องศา ]
local function ToggleSpin()
    SpinActive = not SpinActive
    if SpinActive then
        task.spawn(function()
            while SpinActive do
                pcall(function()
                    local char = LocalPlayer.Character
                    local rootJoint = char.LowerTorso:FindFirstChild("Root") or char.HumanoidRootPart:FindFirstChild("RootJoint")
                    if rootJoint then
                        rootJoint.C0 = rootJoint.C0 * CFrame.Angles(0, math.rad(45), 0)
                    end
                end)
                RunService.RenderStepped:Wait()
            end
            pcall(function()
                local rootJoint = LocalPlayer.Character.LowerTorso:FindFirstChild("Root") or LocalPlayer.Character.HumanoidRootPart:FindFirstChild("RootJoint")
                if rootJoint then rootJoint.C0 = CFrame.new(0, 0, 0) * CFrame.Angles(math.rad(-90), 0, math.rad(180)) end
            end)
        end)
    end
end

