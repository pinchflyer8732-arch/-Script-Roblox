-- [ ระบบ ESP Engine ]
EspBtn.MouseButton1Click:Connect(function()
    if EspActive then return end
    EspActive = true
    EspBtn.Text = "ระบบทำงานแล้ว ✅"
    EspBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    
    task.spawn(function()
        while EspActive do
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    pcall(function()
                        local char = p.Character
                        local hl = char:FindFirstChild("PFirst_Highlight") or Instance.new("Highlight")
                        hl.Name = "PFirst_Highlight"
                        hl.Parent = char
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                        hl.FillTransparency = 0.5
                        
                        local hasKnife = p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                        local hasGun = p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")
                        
                        if hasKnife then hl.FillColor = Color3.fromRGB(255, 0, 0) --
                        elseif hasGun then hl.FillColor = Color3.fromRGB(0, 150, 255) --
                        else hl.FillColor = Color3.fromRGB(0, 255, 0) end --
                    end)
                end
            end
            task.wait(1.5)
        end
    end)
end)
