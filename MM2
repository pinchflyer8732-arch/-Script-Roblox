-- [ 5. ปุ่มฟังก์ชัน ]
local function createBtn(name, color, y, parent, func)
    local b = Instance.new("TextButton")
    b.Parent = parent
    b.Size = UDim2.new(0, 220, 0, 45)
    b.Position = UDim2.new(0.5, -110, 0, y)
    b.BackgroundColor3 = color
    b.Text = name
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.Font = Enum.Font.SourceSansBold
    b.TextSize = 18
    b.MouseButton1Click:Connect(func)
end

-- ปุ่ม ESP ALL (เขียว)
createBtn("ESP: กำลังสแกน", Color3.fromRGB(0, 150, 0), 15, MainScroll, function()
    EspActive = not EspActive
    task.spawn(function()
        while EspActive do
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    pcall(function()
                        local hl = p.Character:FindFirstChild("PFirst_HL") or Instance.new("Highlight", p.Character)
                        hl.Name = "PFirst_HL"
                        local k = p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")
                        local g = p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")
                        if k then hl.FillColor = Color3.fromRGB(255, 0, 0)
                        elseif g then hl.FillColor = Color3.fromRGB(0, 150, 255)
                        else hl.FillColor = Color3.fromRGB(0, 255, 0) end
                    end)
                end
            end
            task.wait(1.2)
        end
    end)
end)

