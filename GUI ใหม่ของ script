-- [ 1. ฟังก์ชัน ESP ผู้เล่น (สแกนหาอาวุธ) ]
local function StartPlayerESP()
    task.spawn(function()
        while true do
            if not EspActive then break end
            for _, player in pairs(game.Players:GetPlayers()) do
                if player ~= game.Players.LocalPlayer and player.Character then
                    pcall(function()
                        local char = player.Character
                        local hl = char:FindFirstChild("PFirst_HL") or Instance.new("Highlight", char)
                        hl.Name = "PFirst_HL"
                        
                        local hasKnife = player.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                        local hasGun = player.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")

                        if hasKnife then
                            hl.FillColor = Color3.fromRGB(255, 0, 0) -- ฆาตกร: แดง
                        elseif hasGun then
                            hl.FillColor = Color3.fromRGB(0, 150, 255) -- นายอำเภอ: ฟ้า
                        else
                            hl.FillColor = Color3.fromRGB(0, 255, 0) -- คนธรรมดา: เขียว
                        end
                    end)
                end
            end
            task.wait(1.2) -- สแกนทุก 1.2 วินาทีตามสไตล์คุณ
        end
    end)
end

-- [ 2. ฟังก์ชัน ESP ปืนตกที่พื้น ]
local function StartGunESP()
    task.spawn(function()
        while true do
            if not EspGunActive then break end
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("TouchTransmitter") and v.Parent and v.Parent.Name == "GunDrop" then
                    pcall(function()
                        local p = v.Parent
                        local hl = p:FindFirstChild("Gun_HL") or Instance.new("Highlight", p)
                        hl.Name = "Gun_HL"
                        hl.FillColor = Color3.fromRGB(255, 255, 0) -- ปืน: เหลือง
                    end)
                end
            end
            task.wait(2)
        end
    end)
end

