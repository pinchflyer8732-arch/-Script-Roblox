-- [ 1. ฟังก์ชัน ESP ผู้เล่น ]
local function StartPlayerESP()
    EspActive = true
    task.spawn(function()
        while EspActive do
            for _, player in pairs(game.Players:GetPlayers()) do
                if player ~= game.Players.LocalPlayer and player.Character then
                    pcall(function()
                        local char = player.Character
                        local hl = char:FindFirstChild("PFirst_HL") or Instance.new("Highlight", char)
                        hl.Name = "PFirst_HL"
                        local k = player.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                        local g = player.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")

                        if k then hl.FillColor = Color3.fromRGB(255, 0, 0)
                        elseif g then hl.FillColor = Color3.fromRGB(0, 150, 255)
                        else hl.FillColor = Color3.fromRGB(0, 255, 0) end
                    end)
                end
            end
            task.wait(1.2)
        end
    end)
end

-- [ 2. ฟังก์ชัน ESP ปืนตก ]
local function StartGunESP()
    EspGunActive = true
    task.spawn(function()
        while EspGunActive do
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("TouchTransmitter") and v.Parent and v.Parent.Name == "GunDrop" then
                    pcall(function()
                        local p = v.Parent
                        local hl = p:FindFirstChild("Gun_HL") or Instance.new("Highlight", p)
                        hl.Name = "Gun_HL"
                        hl.FillColor = Color3.fromRGB(255, 255, 0)
                    end)
                end
            end
            task.wait(2)
        end
    end)
end

