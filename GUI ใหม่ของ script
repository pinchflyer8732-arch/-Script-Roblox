-- [ ระบบ Loop เบื้องหลัง ]
game:GetService("RunService").Heartbeat:Connect(function()
    if SpinActive and game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = game.Players.LocalPlayer.Character.HumanoidRootPart
        local rotation = hrp.Velocity.Magnitude < 2 and 45 or 15
        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(rotation), 0)
    end
end)
